{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "noUncheckedIndexedAccess": true,
    "types": [
      "@cloudflare/workers-types"
    ]
  },
  "exclude": [
    "vitest.config.ts",
    "drizzle.config.ts",
    "scripts/**/*.ts",
    "node_modules"
  ]
}
